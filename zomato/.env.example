# Environment Configuration

# App Environment
ENV=development

# Gateway
GATEWAY_PORT=8000

# Services
USER_SERVICE_PORT=8001
RESTAURANT_SERVICE_PORT=8002
ORDER_SERVICE_PORT=8003
PAYMENT_SERVICE_PORT=8004
DELIVERY_SERVICE_PORT=8005
REVIEW_SERVICE_PORT=8006
NOTIFICATION_SERVICE_PORT=8007
ADMIN_SERVICE_PORT=8008

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=zomato
DB_PASSWORD=zomato_pass

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# Service URLs (for inter-service communication)
USER_SERVICE_URL=http://localhost:8001
RESTAURANT_SERVICE_URL=http://localhost:8002
ORDER_SERVICE_URL=http://localhost:8003
PAYMENT_SERVICE_URL=http://localhost:8004
DELIVERY_SERVICE_URL=http://localhost:8005
REVIEW_SERVICE_URL=http://localhost:8006
NOTIFICATION_SERVICE_URL=http://localhost:8007
ADMIN_SERVICE_URL=http://localhost:8008

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Payment Gateway (Mock)
PAYMENT_GATEWAY_KEY=test_key_12345
PAYMENT_GATEWAY_SECRET=test_secret_67890

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

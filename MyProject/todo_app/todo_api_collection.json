{
  "info": {
    "_postman_id": "todo-api-collection",
    "name": "TODO API Collection",
    "description": "Complete TODO API collection for Gin-based TODO application with CRUD operations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Check if the API is running"
      },
      "response": []
    },
    {
      "name": "Create Todo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Buy groceries\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/todos",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "todos"
          ]
        },
        "description": "Create a new todo item"
      },
      "response": []
    },
    {
      "name": "Get All Todos",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/todos",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "todos"
          ]
        },
        "description": "Retrieve all todo items"
      },
      "response": []
    },
    {
      "name": "Get Todo by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/todos/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "todos",
            "1"
          ]
        },
        "description": "Get a specific todo by ID"
      },
      "response": []
    },
    {
      "name": "Update Todo",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Buy groceries and milk\",\n  \"completed\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/todos/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "todos",
            "1"
          ]
        },
        "description": "Update an existing todo item"
      },
      "response": []
    },
    {
      "name": "Update Todo - Mark Complete",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"completed\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/todos/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "todos",
            "1"
          ]
        },
        "description": "Mark a todo as completed"
      },
      "response": []
    },
    {
      "name": "Update Todo - Mark Incomplete",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"completed\": false\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/todos/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "todos",
            "1"
          ]
        },
        "description": "Mark a todo as incomplete"
      },
      "response": []
    },
    {
      "name": "Delete Todo",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/todos/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "todos",
            "1"
          ]
        },
        "description": "Delete a specific todo item"
      },
      "response": []
    },
    {
      "name": "Delete All Todos",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/todos",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "todos"
          ]
        },
        "description": "Delete all todo items"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}
